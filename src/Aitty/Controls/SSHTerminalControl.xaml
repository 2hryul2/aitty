<UserControl x:Class="Aitty.Controls.SSHTerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:term="clr-namespace:Aitty.Terminal"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header bar -->
            <RowDefinition Height="Auto" />   <!-- Connection form -->
            <RowDefinition Height="*"    />   <!-- Terminal area -->
            <RowDefinition Height="Auto" />   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0d1a0d" BorderBrush="#1a3a1a" BorderThickness="0,0,0,1" Padding="12,6">
            <DockPanel>
                <TextBlock Text="SSH Terminal" Foreground="#00ff00" FontFamily="Consolas"
                           FontSize="13" FontWeight="Bold" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#555" Margin="0,0,6,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText" Text="Disconnected" Foreground="#555"
                               FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Connection Form -->
        <Border x:Name="ConnectForm" Grid.Row="1"
                Background="#0a150a" BorderBrush="#1a3a1a" BorderThickness="0,0,0,1" Padding="12,8">
            <WrapPanel Orientation="Horizontal">

                <!-- Host -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Host:" Foreground="#666" FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBox x:Name="HostBox" Width="140" Text="127.0.0.1"
                             Background="#111" Foreground="#00cc00" CaretBrush="#00ff00"
                             BorderBrush="#333" FontFamily="Consolas" FontSize="11" Padding="4,2" />
                </StackPanel>

                <!-- Port -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Port:" Foreground="#666" FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBox x:Name="PortBox" Width="50" Text="22"
                             Background="#111" Foreground="#00cc00" CaretBrush="#00ff00"
                             BorderBrush="#333" FontFamily="Consolas" FontSize="11" Padding="4,2" />
                </StackPanel>

                <!-- User -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="User:" Foreground="#666" FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBox x:Name="UserBox" Width="100" Text="sds"
                             Background="#111" Foreground="#00cc00" CaretBrush="#00ff00"
                             BorderBrush="#333" FontFamily="Consolas" FontSize="11" Padding="4,2" />
                </StackPanel>

                <!-- Password -->
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="Pass:" Foreground="#666" FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <PasswordBox x:Name="PassBox" Width="100"
                                 Background="#111" Foreground="#00cc00" CaretBrush="#00ff00"
                                 BorderBrush="#333" FontFamily="Consolas" FontSize="11" Padding="4,2" />
                </StackPanel>

                <!-- Connect / Disconnect buttons -->
                <Button x:Name="ConnectBtn" Content="Connect" Click="ConnectBtn_Click"
                        Background="#1a3a1a" Foreground="#00ff00" BorderBrush="#00aa00"
                        FontFamily="Consolas" FontSize="11" Padding="12,3" Margin="0,0,6,0"
                        Cursor="Hand" />
                <Button x:Name="DisconnectBtn" Content="Disconnect" Click="DisconnectBtn_Click"
                        Background="#2a1a1a" Foreground="#ff4444" BorderBrush="#aa2222"
                        FontFamily="Consolas" FontSize="11" Padding="12,3"
                        IsEnabled="False" Cursor="Hand" />
            </WrapPanel>
        </Border>

        <!-- Terminal: TerminalControl fills the area, handles its own keyboard + scroll -->
        <term:TerminalControl x:Name="Term" Grid.Row="2"
                              Focusable="True" />

    </Grid>
</UserControl>
